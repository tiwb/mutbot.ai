---
---

<div id="landing">
  <!-- Header -->
  <header class="fixed top-0 w-full z-50 border-b border-white/5 bg-gray-950/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight">MutBot</a>
      <a
        href="https://github.com/tiwb/mutbot"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-white transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-6xl sm:text-7xl font-bold tracking-tight mb-6">
        MutBot
      </h1>
      <p class="text-xl sm:text-2xl text-gray-400 mb-12">Define Your AI</p>

      <!-- Install command -->
      <div class="inline-flex items-center gap-3 bg-gray-900 border border-white/10 rounded-lg px-5 py-3 mb-6">
        <code class="text-sm sm:text-base text-emerald-400 font-mono select-all">
          curl -LsSf https://mutbot.ai/install.sh | sh
        </code>
        <button
          id="copy-btn"
          class="text-gray-500 hover:text-white transition-colors shrink-0 cursor-pointer"
          title="Copy to clipboard"
        >
          <svg id="copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
          </svg>
          <svg id="check-icon" class="w-4 h-4 hidden text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>

      <div>
        <a
          href="http://localhost:8741"
          class="inline-block text-sm text-gray-500 hover:text-gray-300 transition-colors mt-2"
        >
          Open local MutBot &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-gray-900/50 border border-white/5 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-violet-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 007.92 12.446A9 9 0 1112 2.992z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">You Define</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Shape your AI's behavior through natural conversation. Your preferences become its instincts.
        </p>
      </div>

      <div class="bg-gray-900/50 border border-white/5 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Always Evolving</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Learns and adapts as you work. The more you use it, the better it understands you.
        </p>
      </div>

      <div class="bg-gray-900/50 border border-white/5 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-sky-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="2" y="2" width="20" height="20" rx="5"></rect>
            <path d="M12 8v4l3 3"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Fully Local</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Runs entirely on your machine. Your data never leaves your device. Fully private.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-8 px-6">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <span>&copy; 2026 MutBot</span>
      <div class="flex gap-6">
        <a href="https://github.com/tiwb/mutbot" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">GitHub</a>
        <a href="https://github.com/tiwb/mutbot#readme" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">Docs</a>
        <a href="https://github.com/tiwb/mutbot/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">License</a>
      </div>
    </div>
  </footer>
</div>

<script>
  const btn = document.getElementById("copy-btn")!;
  const copyIcon = document.getElementById("copy-icon")!;
  const checkIcon = document.getElementById("check-icon")!;

  btn.addEventListener("click", async () => {
    await navigator.clipboard.writeText(
      "curl -LsSf https://mutbot.ai/install.sh | sh"
    );
    copyIcon.classList.add("hidden");
    checkIcon.classList.remove("hidden");
    setTimeout(() => {
      checkIcon.classList.add("hidden");
      copyIcon.classList.remove("hidden");
    }, 2000);
  });
</script>
