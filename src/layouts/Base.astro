---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Your personal AI assistant that evolves to match your work style. Runs locally, fully private.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Your personal AI assistant. Runs locally." />
    <meta property="og:url" content="https://mutbot.ai" />
    <link rel="canonical" href="https://mutbot.ai" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-gray-950 text-white min-h-screen antialiased">
    <slot />
  </body>
</html>
