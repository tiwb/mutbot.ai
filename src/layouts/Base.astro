---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Your personal AI assistant that evolves to match your work style. Runs locally, fully private.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Your personal AI assistant. Runs locally." />
    <meta property="og:url" content="https://mutbot.ai" />
    <link rel="canonical" href="https://mutbot.ai" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // 内联在 <head>，DOM 渲染前执行 — 有 hash 时隐藏 landing 显示 app
      if (location.hash && location.hash.length > 1) {
        document.documentElement.classList.add('app-mode');
      }
    </script>
    <style is:inline>
      .app-mode #landing { display: none !important; }
      .app-mode #app { display: block !important; height: 100vh; }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen antialiased font-sans">
    <slot />
  </body>
</html>
